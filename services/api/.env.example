# HTTP server
HTTP_ADDR=:8080

# Logger: level = debug | info | warning | error
LOGGER_LEVEL=info
# Logger: format = console | json
LOGGER_FORMAT=console

# PostgreSQL connection string (required)
DATABASE_DSN=postgres://postgres:postgres@localhost:5432/asl_core?sslmode=disable
# Connection pool
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_CONN_LIFETIME=1h

# Migrations: source path read by cmd/migrate (run from the repo root)
MIGRATION_SOURCE=file://migrations/api
